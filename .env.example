# =====================================================
# YouTube Summarizer - 환경 변수 설정
# 이 파일을 복사해서 .env로 만들고 값을 채워주세요
# cp .env.example .env
# =====================================================

# ── LLM 설정 ─────────────────────────────────────
# 요약에 사용할 LLM 제공자: gemini 또는 openrouter
LLM_PROVIDER=openrouter

# [Gemini] https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [OpenRouter] https://openrouter.ai/keys
# 무료 모델 목록: https://openrouter.ai/models?q=free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# ── Google 설정 ───────────────────────────────────
# OAuth 클라이언트 ID/Secret (credentials/google_credentials.json 파일로도 가능)
DRIVE_CLIENT_ID=
DRIVE_CLIENT_SECRET=

# 구글 드라이브 폴더 ID (선택사항)
GOOGLE_DRIVE_FOLDER_ID=

# Google Sheets 스프레드시트 ID (요약 저장용)
# URL에서 추출: https://docs.google.com/spreadsheets/d/[여기]/edit
SPREADSHEET_ID=

# ── YouTube 채널 ──────────────────────────────────
# 콤마로 구분 (선택사항 - 웹 UI에서도 추가 가능)
YOUTUBE_CHANNELS=

# ── Whisper 설정 (음성 인식) ──────────────────────
# 모델 크기: tiny / base / small / medium / large-v3-turbo
# GPU 없으면 base 권장, RTX 4060 Ti 이상이면 large-v3-turbo 가능
WHISPER_MODEL=large-v3-turbo
CUDA_VISIBLE_DEVICES=0

# ── 앱 설정 ──────────────────────────────────────
CHECK_INTERVAL_HOURS=1
TTS_METHOD=gtts
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=false
JWT_SECRET_KEY=change-this-to-another-random-string
RUN_MODE=all
WEB_HOST=0.0.0.0
WEB_PORT=5000
DB_PATH=data/youtube_summarizer.db
