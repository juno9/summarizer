# YouTube Summarizer 설정

# Gemini API 키 (필수) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 유튜브 채널 URL (콤마로 구분, 선택사항 - 웹 UI에서도 추가 가능)
YOUTUBE_CHANNELS=https://www.youtube.com/@channel1,https://www.youtube.com/@channel2

# 구글 드라이브 폴더 ID (선택사항)
GOOGLE_DRIVE_FOLDER_ID=

# 체크 주기 (시간 단위, 기본: 1) - Rate limit 방지를 위해 6시간 권장
CHECK_INTERVAL_HOURS=6

# TTS 방식 (gtts 또는 coqui)
TTS_METHOD=gtts

# 로컬 LLM 사용 여부 (true/false) - RTX 4060 Ti 최적화
USE_LOCAL_LLM=true

# Whisper 모델 크기 (tiny, base, small, medium, large) - base 추천 (8GB VRAM)
WHISPER_MODEL=base

# GPU 가속 설정
CUDA_VISIBLE_DEVICES=0

# Flask 설정
FLASK_SECRET_KEY=your-secret-key-change-this
FLASK_DEBUG=false

# JWT 설정 (앱용 API 토큰)
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# 실행 모드 (all, web, worker)
RUN_MODE=all

# 웹 서버 설정
WEB_HOST=0.0.0.0
WEB_PORT=5000

# DB 경로
DB_PATH=/app/data/youtube_summarizer.db
